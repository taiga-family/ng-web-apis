{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "payment-request",
    "projectType": "library",
    "sourceRoot": "libs/payment-request",
    "targets": {
        "build": {
            "dependsOn": [
                {
                    "dependencies": true,
                    "params": "forward",
                    "target": "build"
                }
            ],
            "executor": "@angular-devkit/build-angular:ng-packagr",
            "options": {
                "project": "libs/{projectName}/ng-package.json",
                "tsConfig": "tsconfig.build.json"
            },
            "outputs": ["{workspaceRoot}/dist/{projectName}"]
        },
        "publish": {
            "dependsOn": [
                {
                    "dependencies": false,
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "commands": ["cp ./LICENSE ./dist/{projectName}", "npm publish ./dist/{projectName} --ignore-scripts"],
                "parallel": false
            }
        },
        "test": {
            "executor": "@angular-devkit/build-angular:karma",
            "options": {
                "browsers": "ChromeHeadless",
                "codeCoverage": true,
                "karmaConfig": "libs/{projectName}/karma.conf.js",
                "main": "libs/{projectName}/test.ts",
                "tsConfig": "tsconfig.spec.json"
            },
            "outputs": ["{workspaceRoot}/coverage/{projectName}"]
        }
    }
}
